<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    tools:context=".fragments.user.edit.EditUserFragment">

    <data>
        <variable
            name="viewModel"
            type="com.example.matchtail.fragments.user.edit.EditUserViewModel" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F8F9FA">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/editUserToolbar"
            android:layout_width="match_parent"
            android:layout_height="?android:attr/actionBarSize"
            android:background="@color/matchtail_green"
            app:layout_constraintTop_toTopOf="parent"
            app:theme="@style/Theme.AppCompat.DayNight.NoActionBar">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/edit_profile"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold" />
        </androidx.appcompat.widget.Toolbar>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:fillViewport="true"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/editUserToolbar">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <com.example.matchtail.views.ImagePicker
                            android:id="@+id/imageView"
                            android:layout_width="120dp"
                            android:layout_height="120dp"
                            android:layout_gravity="center"
                            android:layout_marginBottom="24dp"
                            android:src="@drawable/avatar_image" />

                        <com.example.matchtail.views.EditTextInput
                            android:id="@+id/name"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:hint="@string/full_name"
                            android:text="@={viewModel.name}"
                            android:inputType="textPersonName" />

                        <com.example.matchtail.views.EditTextInput
                            android:id="@+id/phone"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:hint="@string/phone_number"
                            android:text="@={viewModel.phone}"
                            android:inputType="phone" />

                        <com.example.matchtail.views.EditTextInput
                            android:id="@+id/location"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:text="@={viewModel.location}"
                            android:hint="@string/location_city" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/role_prompt"
                            android:layout_marginBottom="8dp"
                            android:textColor="@color/black"
                            android:textStyle="bold"/>

                        <RadioGroup
                            android:id="@+id/roleGroup"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="12dp">
                            <RadioButton
                                android:id="@+id/roleAdopter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/adopt_pet"
                                android:layout_marginEnd="16dp"/>
                            <RadioButton
                                android:id="@+id/roleGiver"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/send_pet"/>
                        </RadioGroup>

                        <com.example.matchtail.views.EditTextInput
                            android:id="@+id/description"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="24dp"
                            android:hint="@string/about_me"
                            android:text="@={viewModel.description}"
                            android:lines="3" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#EEEEEE"
                            android:layout_marginBottom="24dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/change_password_optional"
                            android:layout_marginBottom="12dp"
                            android:textColor="@color/black"
                            android:textStyle="bold"/>

                        <com.example.matchtail.views.EditTextInput
                            android:id="@+id/oldPassword"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:hint="@string/old_password_text"
                            android:text="@={viewModel.oldPassword}"
                            android:inputType="textPassword" />

                        <com.example.matchtail.views.EditTextInput
                            android:id="@+id/password"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:hint="@string/new_password"
                            android:text="@={viewModel.password}"
                            android:inputType="textPassword" />

                        <com.example.matchtail.views.EditTextInput
                            android:id="@+id/confirmPassword"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="24dp"
                            android:hint="@string/confirm_new_password"
                            android:text="@={viewModel.confirmPassword}"
                            android:inputType="textPassword" />

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <Button
                                android:id="@+id/submitButton"
                                android:layout_width="match_parent"
                                android:layout_height="56dp"
                                android:backgroundTint="@color/matchtail_green"
                                android:text="@string/save_changes"
                                android:textAllCaps="false"
                                android:textSize="18sp"
                                app:cornerRadius="8dp" />

                            <com.google.android.material.progressindicator.CircularProgressIndicator
                                android:id="@+id/progressBar"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:indeterminate="true"
                                android:visibility="invisible" />
                        </FrameLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>